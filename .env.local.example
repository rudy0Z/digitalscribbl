# ============================================================
# Scribbl — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to client
# Used for admin operations and server-side compositing
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
# NEXT_PUBLIC_SITE_URL is preferred. NEXT_PUBLIC_APP_URL is still accepted
# for older local env files.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dev auth bypass (local-only testing) ---
# Set DEV_AUTH_BYPASS=true and map up to 4 existing user IDs from your users table.
# Open /dev/test-users, then use one browser per generated link.
DEV_AUTH_BYPASS=false
DEV_AUTH_USER_1_ID=
DEV_AUTH_USER_2_ID=
DEV_AUTH_USER_3_ID=
DEV_AUTH_USER_4_ID=

# --- Email Domain Restriction ---
# Comma-separated list of allowed email domains for Google OAuth
# Example: college.edu,university.ac.in
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=yourcollege.edu

# --- Google OAuth ---
# Configured in Supabase Auth, no separate keys needed here.
# Set the callback URL in Supabase: {NEXT_PUBLIC_SITE_URL}/auth/callback

# --- Storage Buckets (create these in Supabase Storage) ---
# avatar-heads   — public read
# shirt-textures — public read

# --- Shirt Canvas Dimensions ---
# These match the server-side compositing constants in lib/constants.ts
# Do not change after launch without migrating existing textures.
# SHIRT_CANVAS_WIDTH=400
# SHIRT_CANVAS_HEIGHT=600
